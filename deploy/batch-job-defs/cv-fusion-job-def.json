{
  "jobDefinitionName": "cv-fusion",
  "type": "container",
  "platformCapabilities": ["EC2"],
  "propagateTags": true,
  "retryStrategy": {
    "attempts": 2,
    "evaluateOnExit": [
      { "action": "RETRY", "onStatusReason": "Host EC2*" },
      { "action": "RETRY", "onReason": "Task failed to start" },
      { "action": "EXIT",  "onExitCode": "1" }
    ]
  },
  "timeout": { "attemptDurationSeconds": 2700 },
  "containerProperties": {
    "image": "PLACEHOLDER_ECR_IMAGE_URI",
    "command": [],
    "vcpus": 4,
    "memory": 16384,
    "jobRoleArn": "PLACEHOLDER_CV_BATCH_JOB_ROLE_ARN",
    "executionRoleArn": "PLACEHOLDER_CV_BATCH_EXECUTION_ROLE_ARN",
    "resourceRequirements": [
      { "type": "GPU",    "value": "1" },
      { "type": "VCPU",   "value": "4" },
      { "type": "MEMORY", "value": "16384" }
    ],
    "environment": [
      { "name": "AWS_REGION",    "value": "us-east-1" },
      { "name": "MODEL_VERSION", "value": "v1" },
      { "name": "LOG_LEVEL",     "value": "INFO" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group":         "/aws/batch/cv-fusion",
        "awslogs-region":        "us-east-1",
        "awslogs-stream-prefix": "cv-fusion",
        "awslogs-create-group":  "true"
      }
    }
  },
  "tags": {
    "service":  "cv-shot-detection",
    "pipeline": "v1"
  }
}
