# --- Required ---

# Tailscale ephemeral auth key (tskey-auth-...). Expires 2026-07-08.
# Create at: https://login.tailscale.com/admin/settings/keys
# Must be: Reusable + Ephemeral + (tag if your ACLs require one)
TAILSCALE_AUTH_KEY=tskey-auth-REPLACE_ME

# Tailscale API key (tskey-api-...). Used to list devices + lastSeen.
# Create at: https://login.tailscale.com/admin/settings/keys (API access keys tab)
TAILSCALE_API_KEY=tskey-api-REPLACE_ME

# SMTP credentials for sending the alert email.
# Defaults below are for GoDaddy / Secureserver (courtside@uai.tech mailbox).
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587
SMTP_USER=courtside@uai.tech
SMTP_PASSWORD=REPLACE_ME
SMTP_FROM_EMAIL=courtside@uai.tech
ALERT_TO_EMAIL=courtside@uai.tech

# --- Optional (defaults shown) ---

# EXPECTED_GOPROS_PER_JETSON=2
# CHECK_TIMEOUT=15
# STALE_THRESHOLD_MIN=5

# Override the Jetson list as JSON if the hardcoded defaults ever drift.
# JETSON_DEVICES=[{"name":"Jetson Nano 1","tailscale_hostname":"jetson-nano-002","tailscale_ip":"100.87.190.71"},{"name":"Jetson Nano 2","tailscale_hostname":"JETSON-NANO-001","tailscale_ip":"100.106.30.98"}]
