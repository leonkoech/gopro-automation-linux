# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# Upload settings
UPLOAD_ENABLED=true
UPLOAD_LOCATION=default-location
UPLOAD_DEVICE_NAME=jetson-nano-01
UPLOAD_BUCKET=jetson-videos
UPLOAD_REGION=us-east-1
DELETE_AFTER_UPLOAD=false

# Firebase Admin SDK settings
FIREBASE_CREDENTIALS_PATH=/path/to/uball-gopro-fleet-firebase-adminsdk.json
JETSON_ID=jetson-1
# Court location for S3 paths (e.g., "court-a")
COURT_LOCATION=court-a
# Map GoPro camera names to angle codes (JSON format)
CAMERA_ANGLE_MAP={"GoPro FL": "FL", "GoPro FR": "FR", "GoPro NL": "NL", "GoPro NR": "NR"}

# Uball Backend settings (for game sync)
UBALL_BACKEND_URL=https://api.uball.example.com
UBALL_AUTH_EMAIL=your_email@example.com
UBALL_AUTH_PASSWORD=your_password_here

# AWS Batch GPU Transcoding (4K->1080p encoding via cloud GPU)
AWS_BATCH_JOB_QUEUE=gpu-transcode-queue
AWS_BATCH_JOB_DEFINITION=ffmpeg-nvenc-transcode
AWS_BATCH_REGION=us-east-1

# Z-CAM E2-N Streaming Pipeline
# JSON array of camera configs (set to [] to disable Z-CAM module)
ZCAM_CAMERAS=[{"cam_id":"zcam-1","ip":"192.168.1.101","ndi_name":"ZCAM-E2-N (cam1)","kvs_stream_name":"zcam-court-left","label":"Court Left"},{"cam_id":"zcam-2","ip":"192.168.1.102","ndi_name":"ZCAM-E2-N (cam2)","kvs_stream_name":"zcam-court-right","label":"Court Right"}]
ZCAM_PLATFORM=auto
ZCAM_BITRATE=4000000
ZCAM_SW_BITRATE=4000
ZCAM_KVS_REGION=us-east-1
ZCAM_S3_PREFIX=zcam-recordings
ZCAM_DOWNLOAD_DIR=~/zcam_downloads
ZCAM_POLL_INTERVAL=5
# AWS Batch Extract+Transcode Job Definition
# Single Batch job for extract+transcode (no intermediate 4K file)
AWS_BATCH_JOB_DEFINITION_EXTRACT=ffmpeg-extract-transcode:4

# Annotator email notification (sent once per pipeline when games are ready)
ANNOTATOR_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=pervaizmusharaf51@gmail.com
SMTP_PASSWORD=replace_with_gmail_app_password
SMTP_FROM_EMAIL=pervaizmusharaf51@gmail.com
ANNOTATOR_NOTIFY_EMAIL=sivakumarvr.icons@gmail.com
ANNOTATOR_NOTIFY_CC=courtside@uai.tech
ANNOTATION_TOOL_URL=https://uball-datacollection.vercel.app
